{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "api/**/*",
    "_server-lib/**/*",
    "src/services/ai/**/*",
    "src/types.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
