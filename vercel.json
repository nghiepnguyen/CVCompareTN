{
  "version": 2,
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/api/config",
      "destination": "/api/config.ts"
    },
    {
      "source": "/api/verify-recaptcha",
      "destination": "/api/verify-recaptcha.ts"
    },
    {
      "source": "/api/send-email",
      "destination": "/api/send-email.ts"
    },
    {
      "source": "/api/extract-pdf",
      "destination": "/api/extract-pdf.ts"
    },
    {
      "source": "/api/payment/:action(create|confirm|webhook)",
      "destination": "/api/payment.ts"
    },
    {
      "source": "/api/recruiter/save-analysis",
      "destination": "/api/recruiter/save-analysis.ts"
    },
    {
      "source": "/api/analyze",
      "destination": "/api/analyze.ts"
    },
    {
      "source": "/((?!api|src|node_modules|@vite|@react-refresh|assets|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/analyze.ts": {
      "maxDuration": 60
    },
    "api/*.ts": {
      "maxDuration": 30
    },
    "api/recruiter/*.ts": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/privacy",
      "destination": "/vi/privacy",
      "permanent": true
    },
    {
      "source": "/terms",
      "destination": "/vi/terms",
      "permanent": true
    },
    {
      "source": "/support",
      "destination": "/vi/support",
      "permanent": true
    },
    {
      "source": "/upgrade",
      "destination": "/vi/upgrade",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/vi/about",
      "permanent": true
    },
    {
      "source": "/en",
      "destination": "/en/",
      "permanent": true
    },
    {
      "source": "/vi",
      "destination": "/vi/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}