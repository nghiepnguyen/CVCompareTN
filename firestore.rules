rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // AUTH & ROLE HELPERS
    // ===============================================================
    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuth() && 
        (userDoc().data.role == 'admin' || 
         (request.auth.token.email.matches(".*@gmail.com") && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ===============================================================
    // VALIDATION HELPERS
    // ===============================================================
    function isString(field, min, max) {
      return field is string && field.size() >= min && field.size() <= max;
    }

    function isTime(field) {
      return field is timestamp || field is number;
    }

    // ===============================================================
    // COLLECTION RULES
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuth() && (isOwner(userId) || isAdmin());
      
      allow create: if isAuth() 
        && isOwner(userId)
        && isString(request.resource.data.displayName, 1, 100)
        && isString(request.resource.data.email, 5, 200)
        && request.resource.data.role in ['user', 'admin']
        && isTime(request.resource.data.createdAt);

      allow update: if isAuth() 
        && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));

      allow delete: if isAdmin();

      // --- Nested: Analysis History ---
      match /history/{resultId} {
        allow read: if isAuth() && (isOwner(userId) || isAdmin());
        
        allow create: if isAuth() 
          && isOwner(userId)
          && isString(request.resource.data.cvName, 1, 255)
          && request.resource.data.matchScore >= 0 
          && request.resource.data.matchScore <= 100
          && isTime(request.resource.data.timestamp)
          && request.resource.data.userId == request.auth.uid;

        allow update: if isAuth() && (isOwner(userId) || isAdmin());
        allow delete: if isAuth() && (isOwner(userId) || isAdmin());
      }

      // --- Nested: Saved JDs ---
      match /savedJDs/{jdId} {
        allow read: if isAuth() && (isOwner(userId) || isAdmin());
        
        allow create: if isAuth() 
          && isOwner(userId)
          && isString(request.resource.data.title, 1, 500)
          && isString(request.resource.data.content, 1, 50000)
          && isTime(request.resource.data.timestamp);

        allow update: if isAuth() && isOwner(userId) && isString(request.resource.data.content, 1, 50000);
        allow delete: if isAuth() && (isOwner(userId) || isAdmin());
      }
    }

    // ===============================================================
    // GLOBAL DEFAULT
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
