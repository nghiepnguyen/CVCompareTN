{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "defaultAvatarURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "hasPermission": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "usageCount": { "type": "number" },
        "isNew": { "type": "boolean" }
      },
      "required": ["uid", "email", "displayName", "role", "createdAt", "usageCount"]
    },
    "AnalysisResult": {
      "title": "Analysis Result",
      "description": "The result of a CV vs JD analysis",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the result" },
        "timestamp": { "type": "number", "description": "Time of analysis" },
        "cvName": { "type": "string", "description": "Name of the CV file" },
        "jdTitle": { "type": "string", "description": "Summary of the JD" },
        "jobTitle": { "type": "string", "description": "Job Title extracted from the JD" },
        "matchScore": { "type": "number", "description": "Overall ATS match score" },
        "categoryScores": {
          "type": "object",
          "properties": {
            "skills": { "type": "number" },
            "experience": { "type": "number" },
            "tools": { "type": "number" },
            "education": { "type": "number" }
          }
        },
        "passProbability": { "type": "string", "enum": ["Cao", "Trung bình", "Thấp"] },
        "passExplanation": { "type": "string" },
        "mainFactor": { "type": "string" },
        "matchingPoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "point": { "type": "string" },
              "category": { "type": "string" }
            }
          }
        },
        "missingGaps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "gap": { "type": "string" },
              "category": { "type": "string" }
            }
          }
        },
        "atsKeywords": { "type": "array", "items": { "type": "string" } },
        "rewriteSuggestions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": { "type": "string" },
              "original": { "type": "string" },
              "optimized": { "type": "string" },
              "explanation": { "type": "string" }
            }
          }
        },
        "fullRewrittenCV": { "type": "string" },
        "cvUrl": { "type": "string", "description": "URL of the CV file in Storage" },
        "jdUrl": { "type": "string", "description": "URL of the JD file in Storage (if uploaded)" },
        "userId": { "type": "string", "description": "User ID of the owner" },
        "rating": { "type": "number", "description": "User rating (1-5)" },
        "feedback": { "type": "string", "description": "User feedback text" },
        "ratedAt": { "type": "number", "description": "Timestamp of rating" }
      },
      "required": ["id", "timestamp", "cvName", "matchScore", "userId"]
    },
    "SavedJD": {
      "title": "Saved JD",
      "description": "A job description saved by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "title", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile and settings"
    },
    "/users/{userId}/history/{resultId}": {
      "schema": "AnalysisResult",
      "description": "User's analysis history"
    },
    "/users/{userId}/savedJDs/{jdId}": {
      "schema": "SavedJD",
      "description": "User's saved job descriptions"
    }
  }
}
