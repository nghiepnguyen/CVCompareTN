# Build-time environment variables (Frontend)
VITE_GA_MEASUREMENT_ID=your_ga_measurement_id
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Supabase Configuration (Frontend)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini (server-only — used by /api/analyze serverless function, never exposed to browser)
GEMINI_API_KEY=your_gemini_api_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev
FEEDBACK_RECIPIENT_EMAIL=admin@example.com
VITE_FEEDBACK_RECIPIENT_EMAIL=admin@example.com

# PayOS Pro (server-only — Vercel Dashboard / local .env)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_URL=https://cvfit.pro
