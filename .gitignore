# Supabase CLI local cache (pooler URL, project ref, linked project — sensitive / machine-specific)
supabase/.temp/

# Vercel (tokens & project linkage)
.vercel

# Local exports / one-off backups (may contain PII)
users_backup.json
*-backup.json

# Graphify AST cache (regenerated by `graphify update`; keep GRAPH_REPORT.md / graph.json if needed)
graphify-out/cache/
